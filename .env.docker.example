# Docker Compose 暴露到宿主机的端口
LEETCODE_CLAW_HOST_PORT=10170
MYSQL_HOST_PORT=3307

# API 服务配置
LEETCODE_CLAW_READ_TIMEOUT=30s
LEETCODE_CLAW_WRITE_TIMEOUT=120s
LEETCODE_CLAW_UPSTREAM_TIMEOUT=20s
LEETCODE_CLAW_RETRIES=2
LEETCODE_CLAW_CRAWL_ALL_WORKERS=1
LEETCODE_CLAW_CRAWL_ALL_PAGE_SIZE=100
LEETCODE_CLAW_CRAWL_ALL_DELAY=2s
LEETCODE_CLAW_API_KEY=change-me-please
LEETCODE_CLAW_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# MySQL 容器配置
MYSQL_ROOT_PASSWORD=change-root-password
DB_NAME=ptadatabase
DB_USERNAME=leetcode
DB_PASSWORD=change-app-password
